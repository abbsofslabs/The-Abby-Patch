# Stripe — server reads these. Restart with: npm run dev
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_PRICE_SINGLE=price_your_single_pattern_price_id
STRIPE_PRICE_SUB=price_your_subscription_price_id

# Stripe checkout server port (do NOT use PORT — Create React App uses that for the web app)
CHECKOUT_SERVER_PORT=4242

# Optional client-side price IDs (backward compatible; server also reads these)
REACT_APP_STRIPE_SINGLE=price_your_single_pattern_price_id
REACT_APP_STRIPE_SUB=price_your_subscription_price_id

# Production only: URL of your deployed checkout server (e.g. https://api.yoursite.com)
# REACT_APP_CHECKOUT_API_URL=
