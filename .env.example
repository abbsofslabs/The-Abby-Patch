# --- Local development (.env.local) ---

STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_PRICE_SINGLE=price_your_single_pattern_price_id
STRIPE_PRICE_SUB=price_your_subscription_price_id
CHECKOUT_SERVER_PORT=4242

REACT_APP_STRIPE_SINGLE=price_your_single_pattern_price_id
REACT_APP_STRIPE_SUB=price_your_subscription_price_id

# Replicate SAM2 segmentation (https://replicate.com/account/api-tokens)
REPLICATE_API_TOKEN=r8_your_replicate_token
REPLICATE_SAM2_MODEL=lucataco/segment-anything-2

# Supabase (https://supabase.com/dashboard/project/_/settings/api)
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_PUBLISHABLE_KEY=your_publishable_key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_publishable_key

# --- Production (Vercel env vars + Render env vars) ---
#
# Frontend (Vercel): REACT_APP_CHECKOUT_API_URL = https://your-api.onrender.com
# Frontend (Vercel): REACT_APP_SUPABASE_URL, REACT_APP_SUPABASE_PUBLISHABLE_KEY
# Server (Render): STRIPE_SECRET_KEY, STRIPE_PRICE_SINGLE, STRIPE_PRICE_SUB, REPLICATE_API_TOKEN
# Server (Render): SUPABASE_URL, SUPABASE_PUBLISHABLE_KEY
# GitHub Actions (optional Pages mirror): REACT_APP_CHECKOUT_API_URL
