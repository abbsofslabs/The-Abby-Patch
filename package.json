{
  "name": "quilt-app",
  "version": "0.1.0",
  "private": true,
  "homepage": ".",
  "dependencies": {
    "@stripe/stripe-js": "^9.7.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "multer": "^2.2.0",
    "react": "^19.2.7",
    "react-colorful": "^5.7.0",
    "react-dom": "^19.2.7",
    "react-router": "^7.18.1",
    "react-router-dom": "^7.18.1",
    "react-scripts": "5.0.1",
    "replicate": "^1.4.0",
    "stripe": "^22.2.0",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "cross-env PORT=3000 react-scripts start",
    "server": "node server/index.js",
    "dev": "concurrently -n stripe,app -c blue,green \"npm run server\" \"npm run start\"",
    "build": "react-scripts build",
    "postbuild": "node -e \"require('fs').copyFileSync('build/index.html','build/404.html')\"",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "cross-env": "^7.0.3"
  },
  "engines": {
    "node": ">=18"
  }
}
